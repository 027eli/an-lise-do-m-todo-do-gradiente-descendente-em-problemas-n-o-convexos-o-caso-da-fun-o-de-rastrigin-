# GRADIENTE DESCENDENTE COM PONTOS ALEATORIOS - FUNÇÃO RASTRIGIN

import numpy as np
import matplotlib.pyplot as plt
import time

tempo_inicio = time.time()

# Função Rastrigin
def f(x, y, A=10):
    return (2 * A
            + (x**2 - A * np.cos(2 * np.pi * x))
            + (y**2 - A * np.cos(2 * np.pi * y)))

# Gradiente numérico
def derivada_central_x(f, x, y, h=1e-5):
    return (f(x + h, y) - f(x - h, y)) / (2 * h)

def derivada_central_y(f, x, y, h=1e-5):
    return (f(x, y + h) - f(x, y - h)) / (2 * h)

# PARÂMETROS
alpha_inicial = 0.0001
max_iter = 10000
tolerancia = 1e-6
num_pontos = 1000
intervalo = 5.12  # domínio clássico da Rastrigin


melhor_valor = float("inf")
melhor_x = None
melhor_y = None
melhor_historico_x = None
melhor_historico_y = None
melhor_historico_f = None

todos_f_finais = [] # Inicializa a lista para armazenar os valores finais de f

print("\nEXECUTANDO ",num_pontos,"INICIALIZAÇÕES ALEATÓRIAS...")
print("-" * 50)

# COORDENADAS ALEATORIAS
for ponto in range(num_pontos):

    # Ponto inicial aleatório
    x_atual = np.random.uniform(-intervalo, intervalo)
    y_atual = np.random.uniform(-intervalo, intervalo)

    alpha = alpha_inicial
    f_atual = f(x_atual, y_atual)

    historico_x = [x_atual]
    historico_y = [y_atual]
    historico_f = [f_atual]

    # LOOP PRINCIPAL
    for i in range(max_iter):

        gx = derivada_central_x(f, x_atual, y_atual)
        gy = derivada_central_y(f, x_atual, y_atual)

        x_novo = x_atual - alpha * gx
        y_novo = y_atual - alpha * gy

        f_novo = f(x_novo, y_novo)

        if f_novo < f_atual:

            x_atual, y_atual = x_novo, y_novo
            f_atual = f_novo

            historico_x.append(x_atual)
            historico_y.append(y_atual)
            historico_f.append(f_atual)

            if abs(historico_f[-1] - historico_f[-2]) < tolerancia:
                break

        else:
            alpha *= 0.99  # reduz 1% se passo ruim
    
    todos_f_finais.append(f_atual) # Adiciona o valor final de f para este ponto

    # Atualiza melhor mínimo global
    if f_atual < melhor_valor:
        melhor_valor = f_atual
        melhor_x = x_atual
        melhor_y = y_atual
        melhor_historico_x = historico_x
        melhor_historico_y = historico_y
        melhor_historico_f = historico_f

# RESULTADO FINAL
print("-" * 50)
print("Melhor minímo encontrado entre os",num_pontos,"pontos")
print(f"x* = {melhor_x:.8f}")
print(f"y* = {melhor_y:.8f}")
print(f"f(x*,y*) = {melhor_valor:.10f}")

tempo_fim = time.time()
tempo_decorrido = tempo_fim - tempo_inicio
print(f"\n⏱️  Tempo total de execução: {tempo_decorrido:.2f} segundos")

# CÁLCULO DO DESVIO PADRÃO E MÉDIA
todos_f_finais = np.array(todos_f_finais)
media_f = np.mean(todos_f_finais)
desvio_padrao_f = np.std(todos_f_finais)

print("\n" + "=" * 50)
print("ESTATÍSTICAS DOS MÍNIMOS ENCONTRADOS")
print(f"Média dos valores finais de f: {media_f:.10f}")
print(f"Desvio padrão dos valores finais de f: {desvio_padrao_f:.10f}")
print("=" * 50)

# GRÁFICOS DO MELHOR RESULTADO
historico_x = np.array(melhor_historico_x)
historico_y = np.array(melhor_historico_y)
historico_f = np.array(melhor_historico_f)

margem = intervalo
x_grid = np.linspace(-margem, margem, 1000)
y_grid = np.linspace(-margem, margem, 1000)
X, Y = np.meshgrid(x_grid, y_grid)
Z = f(X, Y)

fig = plt.figure(figsize=(18, 5))

# Superfície 3D
ax1 = fig.add_subplot(131, projection="3d")
ax1.plot_surface(X, Y, Z, cmap="viridis", alpha=0.6)
ax1.plot(historico_x, historico_y, historico_f, color="red")
ax1.set_title("Superfície 3D")

# Contorno
ax2 = fig.add_subplot(132)
cp = ax2.contourf(X, Y, Z, levels=40, cmap="viridis")
fig.colorbar(cp, ax=ax2)
ax2.plot(historico_x, historico_y, color="red")
ax2.set_title("Mapa de Contorno")

# Convergência
ax3 = fig.add_subplot(133)
ax3.plot(historico_f)
ax3.set_title("Convergência de f")
ax3.set_xlabel("Iteração")
ax3.set_ylabel("f(x,y)")
ax3.grid(True)

plt.tight_layout()
plt.savefig("grafico rastrin.png")
plt.show()

# Caractersiticas do GD
print("\n" + "="*50)
print("Gradiente Descendente (GD):")
print("- Gradiente exato (determinístico)")
print("- Menor chance de escapar de mínimos locais")
print("- Convergência suave")
